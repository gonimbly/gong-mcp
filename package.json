{
  "name": "gong-mcp",
  "version": "0.7.0",
  "description": "Self-hosted MCP server for the Gong REST API",
  "main": "dist/index.js",
  "bin": {
    "gong-mcp": "dist/index.js",
    "gong-mcp-setup": "dist/setup.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/server.ts",
    "start": "node dist/index.js",
    "start:http": "node dist/server.js",
    "setup": "tsx src/setup.ts",
    "test": "node --import tsx --test 'src/**/*.test.ts'",
    "smoke:policy": "tsx tests/manual/policy-smoke.ts",
    "smoke:find-calls": "tsx tests/manual/find-calls-smoke.ts",
    "probe:extensive-filter": "tsx tests/manual/extensive-filter-probe.ts",
    "probe:stats-coaching": "tsx tests/manual/stats-coaching-probe.ts",
    "probe:transcript-attribution": "tsx tests/manual/transcript-attribution-probe.ts",
    "postbuild": "chmod +x dist/index.js dist/setup.js",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "probe:all-tools": "tsx tests/manual/all-tools-probe.ts"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "gong",
    "ai",
    "claude",
    "model-context-protocol"
  ],
  "author": "GoNimbly",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@napi-rs/keyring": "^1.3.0",
    "express": "^5.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "semantic-release": "^25.0.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
