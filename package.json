{
  "name": "gong-mcp",
  "version": "0.1.0",
  "description": "Self-hosted MCP server for the Gong REST API",
  "main": "dist/index.js",
  "bin": {
    "gong-mcp": "dist/index.js",
    "gong-mcp-setup": "dist/setup.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "setup": "tsx src/setup.ts",
    "postbuild": "chmod +x dist/index.js dist/setup.js",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "gong",
    "ai",
    "claude",
    "model-context-protocol"
  ],
  "author": "GoNimbly",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
