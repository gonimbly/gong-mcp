# ── Local mode (stdio MCP via Claude Desktop/Code) ─────────────────────────────
# Gong OAuth app (Gong → Settings → Ecosystem → API → Integrations).
# Used by gong_login for the browser PKCE flow; tokens land in the OS keychain.
GONG_OAUTH_CLIENT_ID=your_gong_oauth_client_id
GONG_OAUTH_CLIENT_SECRET=your_gong_oauth_client_secret

# ── Hosted gateway mode (npm run start:http — see docs/remote-gateway.md) ──────
# Public URL of the gateway, no trailing slash
BASE_URL=https://gong-mcp-5nu8.onrender.com

# Google OAuth client for user sign-in (Google Cloud Console → Credentials).
# Authorized redirect URI must be: $BASE_URL/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your_google_client_secret

# Long random string for signing gateway-issued JWTs (openssl rand -hex 32)
SESSION_SIGNING_KEY=change_me

# Org-wide Gong credential (Gong → Settings → API → Access Keys) — server-side only
GONG_ACCESS_KEY=your_gong_access_key
GONG_ACCESS_KEY_SECRET=your_gong_access_key_secret

# Your org's regional API endpoint (shown in Gong → Settings → API).
# Access keys are rejected on the generic api.gong.io.
GONG_BASE_URL=https://us-32447.api.gong.io

# Admins get org-wide data; everyone else is a member (own calls/stats only)
GONG_ADMIN_EMAILS=admin@gonimbly.com

# Optional — Google Workspace domain allowed to sign in (default: gonimbly.com)
#GONG_ALLOWED_DOMAIN=gonimbly.com

# Optional — restrict sign-in to specific emails (unset = whole domain allowed)
#GONG_ALLOWED_EMAILS=person1@gonimbly.com,person2@gonimbly.com

# Optional — port to listen on (Render sets this automatically)
#PORT=8080

# Dev only — use the local keychain token from gong_login instead of access keys
#GONG_DEV_KEYCHAIN_FALLBACK=1
